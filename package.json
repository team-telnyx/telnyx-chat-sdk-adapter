{
  "name": "@telnyx/chat-sdk-adapter",
  "version": "0.0.0",
  "description": "Vercel Chat SDK adapter for Telnyx SMS/MMS",
  "author": "Telnyx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/team-telnyx/telnyx-chat-sdk-adapter.git"
  },
  "homepage": "https://github.com/team-telnyx/telnyx-chat-sdk-adapter#readme",
  "bugs": {
    "url": "https://github.com/team-telnyx/telnyx-chat-sdk-adapter/issues"
  },
  "keywords": [
    "telnyx",
    "sms",
    "mms",
    "chat",
    "chat-sdk",
    "adapter",
    "vercel",
    "webhook"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "rm -rf dist coverage",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@chat-adapter/shared": "^4.20.0"
  },
  "peerDependencies": {
    "chat": "^4.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.29.8",
    "@chat-adapter/state-memory": "^4.26.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "chat": "^4.20.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
